{
    "rules": {
        "blank_line_before_statement": {
            "statements": [
                "break",
                "continue",
                "declare",
                "if",
                "return",
                "throw",
                "try"
            ]
        },
        "trailing_comma_in_multiline": {
            "elements": [
                "arguments",
                "arrays",
                "match",
                "parameters"
            ]
        }
    }
}
